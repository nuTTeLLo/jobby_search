# Frontend local environment overrides
# Copy this file to .env.local for local/custom deployments

# Override the API base URL (leave unset to use the vite.config.js proxy at /api → localhost:8080)
VITE_API_BASE=http://localhost:8080

# Optional: comma-separated extra hostnames to allow in the Vite dev server
# e.g. VITE_EXTRA_HOSTS=my-host.example.com,another-host.example.com
VITE_EXTRA_HOSTS=
