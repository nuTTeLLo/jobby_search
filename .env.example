# Root environment variables (used by docker-compose and MCP server)
# Copy this file to .env and fill in real values

JOBSPY_HOST=0.0.0.0
JOBSPY_PORT=9423
ENABLE_SSE=1

# Database connection (used when docker-compose passes vars to backend)
DB_HOST=localhost
DB_PORT=5432
DB_USER=jobuser
DB_PASSWORD=changeme
DB_NAME=jobtracker
DB_SSLMODE=require

# CORS origins for backend
ALLOWED_ORIGINS=http://localhost:5173
